# Copy this file's contents into Render's "Environment" tab for this service.
# Never commit a real .env file (with actual values) to any repo or share it —
# these are secrets.

# --- Supabase ---
# Project Settings -> API in your Supabase dashboard
SUPABASE_URL=https://uncikyahgkdxpzxvmmdx.supabase.co
SUPABASE_SERVICE_KEY=sb_publishable_lDMUxc1Hkrus7iIX7ToJuQ_PTt6ItqF

# --- Razorpay ---
# Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-secret-key
# Dashboard -> Settings -> Webhooks -> (create one pointing at
# https://YOUR-RENDER-URL/api/webhooks/razorpay) -> copy its secret here
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# --- Google Calendar ---
# The calendar ID behind your "cid=" link — usually just the Gmail address
GOOGLE_CALENDAR_ID=crystalspringsvilla@gmail.com

# --- Email receipt settings ---
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-username
EMAIL_SMTP_PASS=your-smtp-password
EMAIL_SMTP_SECURE=false
EMAIL_FROM="Crystal Springs Villa <no-reply@crystalspringsvilla.com>"

# --- WhatsApp receipt settings ---
WHATSAPP_TWILIO_ACCOUNT_SID=your-twilio-sid
WHATSAPP_TWILIO_AUTH_TOKEN=your-twilio-auth-token
WHATSAPP_TWILIO_FROM_NUMBER=+1415XXXXXXX

# --- CORS ---
# Comma-separated list of domains allowed to call this API. Use * only while testing.
ALLOWED_ORIGINS=*
